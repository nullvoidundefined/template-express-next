{
  "name": "deployments-health-check-dashboard",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter ./server build && pnpm --filter ./web-client build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "test": "pnpm --filter ./server run test",
    "test:coverage": "pnpm --filter ./server run test:coverage",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.1"
  }
}
