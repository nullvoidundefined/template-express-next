# Base URL of the Express API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# PostHog client-side analytics. Omit to disable silently.
# Get your key at https://posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Sentry client-side error tracking. Omit to disable silently.
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
