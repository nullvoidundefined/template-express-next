# URL of the web frontend. Used to build password-reset links in emails.
# Required in production.
CLIENT_URL=http://localhost:3000

# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Database (e.g. Neon, local Postgres). Rotate credentials if ever exposed.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# PEM-encoded CA certificate for SSL verification. Set this when your database provider
# uses a custom CA (e.g. Neon, RDS). Omit for local dev or Railway private networking.
# DATABASE_CA_CERT=

# development | production
NODE_ENV=development

# PostHog server-side analytics. Omit to disable analytics silently.
# POSTHOG_API_KEY=phc_...

# Resend transactional email. Required in production for password-reset emails.
# Get your key at https://resend.com
# RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@example.com

# Sentry error tracking DSN. Omit to disable Sentry silently.
# SENTRY_DSN=https://...@sentry.io/...

# Server port
PORT=3001

# Secret used to sign session tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production
