# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Database (e.g. Neon, local Postgres). Rotate credentials if ever exposed.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# PEM-encoded CA certificate for SSL verification. Set this when your database provider
# uses a custom CA (e.g. Neon, RDS). Omit for local dev or Railway private networking.
# DATABASE_CA_CERT=

# development | production
NODE_ENV=development

# Server port
PORT=3000

REDIS_URL=redis://localhost:6379
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=
ALERT_EMAIL=
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
SCREENSHOTS_DIR=./screenshots
