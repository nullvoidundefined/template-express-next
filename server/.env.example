# Allowed CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Database (e.g. Neon, local Postgres). Rotate credentials if ever exposed.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Set to "true" to verify SSL certs in dev/staging; omit or "false" in local dev.
# DATABASE_SSL_REJECT_UNAUTHORIZED=

# development | production
NODE_ENV=development

# Server port
PORT=3000

REDIS_URL=redis://localhost:6379
GITHUB_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=
ALERT_EMAIL=
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
SCREENSHOTS_DIR=./screenshots
